APP_NAME=Treabo
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.treabo.ru
APP_SERVICE=treabo
APP_NOTICE_DOMAIN=TREABO_

DEFAULT_LANGUAGE=ru
TRANSLATION_ENABLED=false

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=marvel_laravel
DB_USERNAME=marvel_laravel
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

BROADCAST_DRIVER=log
CACHE_DRIVER=redis
QUEUE_CONNECTION=database
SESSION_DRIVER=redis
SESSION_LIFETIME=120

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_CLIENT=predis

FILESYSTEM_DISK=public
# Use r2 in production after the Cloudflare R2 bucket and public CDN domain are ready.
MEDIA_DISK=public
PROFFI_UPLOAD_DISK=public
PROFFI_UPLOAD_PREFIX=proffi

CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=treabo-uploads
CLOUDFLARE_R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
CLOUDFLARE_R2_PUBLIC_URL=https://cdn.treabo.ru
CLOUDFLARE_R2_REGION=auto
CLOUDFLARE_R2_USE_PATH_STYLE_ENDPOINT=true

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
YANDEX_REDIRECT_URI=https://api.treabo.ru/api/auth/oauth/yandex/callback
YANDEX_GEO_API_KEY=

DADATA_API_KEY=
DADATA_SECRET_KEY=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.treabo.ru/api/auth/oauth/google/callback

MAIL_MAILER=log
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=no-reply@treabo.ru
MAIL_FROM_NAME=Treabo

COOKIE_DOMAIN=.treabo.ru

SANCTUM_STATEFUL_DOMAINS=treabo.ru,seller.treabo.ru,api.treabo.ru
PROFFI_ADMIN_TOKEN=CHANGE_ME_ADMIN_TOKEN

SHOP_URL=https://treabo.ru
DASHBOARD_URL=https://seller.treabo.ru

# Treabo manual balance top-up
TREABO_BALANCE_MANUAL_PAYMENT_URL=
TREABO_BALANCE_MANUAL_PAYMENT_EXPIRES_HOURS=24

# Comma-separated admin emails that are automatically granted Marvel admin permissions on login.
TREABO_ADMIN_EMAILS=admin@treabo.example.com
