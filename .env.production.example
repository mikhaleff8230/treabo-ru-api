APP_NAME=Treabo
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.treabo.example.com
APP_SERVICE=treabo
APP_NOTICE_DOMAIN=TREABO_

DEFAULT_LANGUAGE=ro
TRANSLATION_ENABLED=true

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=marvel_laravel
DB_USERNAME=marvel_laravel
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

BROADCAST_DRIVER=log
CACHE_DRIVER=redis
QUEUE_CONNECTION=database
SESSION_DRIVER=redis
SESSION_LIFETIME=120

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_CLIENT=predis

FILESYSTEM_DISK=public
MEDIA_DISK=public
PROFFI_UPLOAD_DISK=public
PROFFI_UPLOAD_PREFIX=proffi

CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=treabo-uploads
CLOUDFLARE_R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
CLOUDFLARE_R2_PUBLIC_URL=https://cdn.treabo.example.com
CLOUDFLARE_R2_REGION=auto
CLOUDFLARE_R2_USE_PATH_STYLE_ENDPOINT=true

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
YANDEX_REDIRECT_URI=https://api.treabo.example.com/api/auth/oauth/yandex/callback
YANDEX_GEO_API_KEY=

DADATA_API_KEY=
DADATA_SECRET_KEY=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.treabo.example.com/api/auth/oauth/google/callback

MAIL_MAILER=log
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=no-reply@treabo.example.com
MAIL_FROM_NAME=Treabo

SANCTUM_STATEFUL_DOMAINS=treabo.example.com,admin.treabo.example.com,api.treabo.example.com
PROFFI_ADMIN_TOKEN=CHANGE_ME_ADMIN_TOKEN

SHOP_URL=https://treabo.example.com
DASHBOARD_URL=https://admin.treabo.example.com

# Treabo manual balance top-up
TREABO_BALANCE_MANUAL_PAYMENT_URL=
TREABO_BALANCE_MANUAL_PAYMENT_EXPIRES_HOURS=24
